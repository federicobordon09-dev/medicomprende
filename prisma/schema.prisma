generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  name           String?
  firstName      String?
  lastName       String?
  age            Int?
  email          String?         @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  accounts       Account[]
  sessions       Session[]
  profiles       FamilyProfile[]
  studies        Study[]
  comparisons    Comparison[]
  alerts         Alert[]
  resetToken     String?         @unique
  resetTokenExpiry DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model FamilyProfile {
  id        String   @id @default(cuid())
  name      String
  relation  String
  color     String   @default("#0D9488")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  studies   Study[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Study {
  id           String           @id @default(cuid())
  title        String
  studyType    String?
  studyDate    DateTime?
  fileUrl      String
  fileHash     String
  fileSize     Int
  fileMimeType String           @default("application/pdf")
  ocrApplied   Boolean          @default(false)
  notes        String?
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId    String?
  profile      FamilyProfile?   @relation(fields: [profileId], references: [id])
  analysis     Analysis?
  comparisons  ComparisonStudy[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  @@index([userId, profileId, createdAt])
}

model Analysis {
  id                     String   @id @default(cuid())
  studyId                String   @unique
  study                  Study    @relation(fields: [studyId], references: [id], onDelete: Cascade)
  summary                String
  overallInterpretation  String
  findings               Json
  medicalTerms           Json
  outOfRangeValues       Json?
  parameterExplanations  Json?
  possibleCauses         Json?
  recommendations        Json?
  suggestedQuestions     Json?
  rawAiResponse          Json?
  promptVersion          String   @default("v2")
  createdAt              DateTime @default(now())
}

model Comparison {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  result    Json
  createdAt DateTime         @default(now())
  studies   ComparisonStudy[]
  @@index([userId, createdAt])
}

model ComparisonStudy {
  comparisonId String
  comparison   Comparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  studyId      String
  study        Study      @relation(fields: [studyId], references: [id])
  orderIndex   Int
  @@id([comparisonId, studyId])
}

model Alert {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyIds    String[]
  type        String
  severity    String
  title       String
  description String
  parameter   String?
  trend       String?
  acknowledged Boolean  @default(false)
  dismissedAt DateTime?
  createdAt   DateTime  @default(now())
  @@index([userId, acknowledged, createdAt])
}
