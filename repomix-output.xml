      const anchor = resolveSvelteComponentAnchor();
      if (anchor && !anchor.__impeccableFrozenAnchor) selectedElement = anchor;
      return;
    }
    const wrapper = document.querySelector('[data-impeccable-variants="' + currentSessionId + '"]');
