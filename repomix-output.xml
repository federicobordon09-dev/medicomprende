    }
    if (Array.isArray(failure.failures)) {
      out.failures = failure.failures.slice(0, 8).map((item) => ({
        ref: item.ref,
        reason: item.reason || item.detail,
        detail: item.detail,
        candidates: Array.isArray(item.candidates)
