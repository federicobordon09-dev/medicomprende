# Base de datos (Neon PostgreSQL)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/medicomprende?sslmode=verify-full

# NextAuth
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=http://localhost:3000

# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_PRO_MODEL=gemini-2.5-flash

# Vercel Blob (opcional, fallback a local si no se configura)
BLOB_READ_WRITE_TOKEN=

# SMTP (feedback widget)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Precios (públicos)
NEXT_PUBLIC_PRO_PLAN_PRICE=3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
